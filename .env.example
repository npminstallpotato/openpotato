# OpenPotato Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── LLM Provider ────────────────────────────────────────────────────────────
# Your API key for the LLM provider (DeepSeek or compatible).
LLM_API_KEY=

# Model to use (default: deepseek-v4-flash).
LLM_MODEL=deepseek-v4-flash

# API base URL (default: https://api.deepseek.com/anthropic).
# Uses Anthropic-compatible format (x-api-key auth, /messages endpoint).
LLM_BASE_URL=https://api.deepseek.com/anthropic

# ── Service Ports ───────────────────────────────────────────────────────────
LLM_PORT=8002
GATEWAY_PORT=8000

# ── Service Hosts ───────────────────────────────────────────────────────────
# Use 127.0.0.1 for local-only access (safer).
# Use 0.0.0.0 to allow network connections.
LLM_HOST=127.0.0.1
GATEWAY_HOST=127.0.0.1

# ── Gateway Authentication (optional) ───────────────────────────────────────
# If set, the gateway requires this key in the X-API-Key header.
GATEWAY_API_KEY=igotyuandme
